# Puzzle 1: "First Brush"
# Goal: Create a single red horizontal stripe
# Concept: Learn that blocks fall through colorers and paint the background
# Difficulty: Tutorial (no pushing required)

width: 8
height: 10

# Player (just watching)
player: 1 8

# Single emitter spawns one block
emitter: 4 0

# Red colorer in the path
colorer: 4 4 red

# Target: one solid red stripe
target: red

# Walls (simple border)
wall: 0 0
wall: 7 0
wall: 0 9
wall: 7 9
# Puzzle 2: "Traffic Light"
# Goal: Create three equal stripes - Red (top/oldest), Yellow (middle), Green (bottom/newest)
# Concept: Timing creates layers - earlier blocks paint higher up
# Difficulty: Easy - must push colorers into correct timing positions
# Solution: Arrange colorers so red falls first, yellow second, green last

width: 12
height: 12

# Player starts in middle
player: 1 6

# Three emitters at different heights (to create natural timing)
emitter: 3 1
emitter: 6 3
emitter: 9 2

# Colorers START in wrong positions - player must fix!
# They need to be pushed so blocks fall in order: red -> yellow -> green
colorer: 4 8 green   # Wrong! Should be at bottom path
colorer: 7 7 red     # Wrong! Should be at top path
colorer: 9 6 yellow  # Wrong! Should be at middle path

# Target: red yellow green (in that order, oldest to newest)
target: red yellow green

# Walls to create channels and constraints
wall: 0 0
wall: 11 0
wall: 0 11
wall: 11 11
wall: 2 5
wall: 5 4
wall: 8 6
# Puzzle 3: "Split Decision"
# Goal: Create ONE stripe that's 50% blue, 50% red (side by side)
# Concept: Multiple blocks falling on SAME tick divide the stripe proportionally
# Difficulty: Medium - requires understanding timing = layers
# Solution: Push colorers to same vertical height so both blocks fall simultaneously

width: 10
height: 10

# Player in middle
player: 5 5

# Two emitters at SAME height (both spawn tick 0)
emitter: 2 1
emitter: 7 1

# Two colorers at DIFFERENT heights initially - player must fix!
colorer: 2 4 blue
colorer: 7 6 red   # Wrong height! Needs to be at y=4 also

# Target: Half blue, half red (order doesn't matter since same layer)
target: blue red

# Walls creating two channels
wall: 0 0
wall: 9 0
wall: 0 9
wall: 9 9
wall: 4 0
wall: 4 1
wall: 4 2
wall: 4 3
wall: 4 4
wall: 4 5
# Puzzle 4: "Gradient"
# Goal: Create four thin stripes - Blue, Red, Green, Yellow (oldest to newest)
# Concept: Precise timing control creates multiple layers
# Difficulty: Hard - tight space, must arrange for exact timing
# Solution: Use walls and positioning to stagger fall times by 1-2 ticks each

width: 11
height: 14

# Player
player: 1 10

# Four emitters in different positions
emitter: 2 1
emitter: 4 2
emitter: 6 1
emitter: 8 3

# Colorers scattered - need careful positioning for timing
colorer: 3 8 yellow
colorer: 5 7 green
colorer: 7 9 red
colorer: 9 6 blue

# Target: blue red green yellow (in timing order)
target: blue red green yellow

# Walls creating complex paths and timing constraints
wall: 0 0
wall: 10 0
wall: 0 13
wall: 10 13
wall: 3 4
wall: 3 5
wall: 5 6
wall: 7 4
wall: 7 5
wall: 9 7
wall: 9 8
# Puzzle 5: "Rainbow Thirds"
# Goal: ONE stripe divided into Red (33%), Green (33%), Blue (33%)
# Concept: Three blocks, same tick, different colors
# Difficulty: Expert - requires perfect timing AND correct coloring
# Solution: Arrange colorers so all 3 blocks travel equal distance before falling

width: 13
height: 12

# Player
player: 6 8

# Three emitters at SAME height (all spawn tick 0)
emitter: 3 1
emitter: 6 1
emitter: 9 1

# Colorers initially at wrong heights - need symmetric arrangement
colorer: 3 5 red
colorer: 6 7 green   # Wrong! Must be at same height as others
colorer: 9 4 blue    # Wrong! Must be at same height as others

# Target: red green blue (all in one layer)
target: red green blue

# Walls creating channels (player must arrange colorers symmetrically)
wall: 0 0
wall: 12 0
wall: 0 11
wall: 12 11
wall: 2 0
wall: 2 1
wall: 2 2
wall: 5 0
wall: 5 1
wall: 5 2
wall: 7 0
wall: 7 1
wall: 7 2
wall: 10 0
wall: 10 1
wall: 10 2
